#!/usr/bin/env python3
# Menu Apple in stile macOS per XFCE: dropdown che si apre dal logo (limone) nel
# pannello. Sostituisce il Whisker menu sul bottone-logo con un vero menu di
# sistema (Informazioni su questo Mac, Impostazioni, Stop/Riavvia/Spegni, ...).
# Il launcher delle app (Launchpad) resta separato, nel dock.
import gi, subprocess, signal, os, platform
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk, GLib

SESSION = "/usr/bin/xfce4-session-logout"
HOME = os.path.expanduser("~")
POWER = os.path.join(HOME, ".local/bin/macos-power-dialog")

CSS = b"""
menu { background-color: rgba(40,40,42,0.94); border-radius: 10px;
       border: 1px solid rgba(255,255,255,0.12); padding: 5px; }
menuitem { color: rgba(255,255,255,0.92); border-radius: 6px; padding: 5px 30px 5px 18px;
           font-family: "SF Pro Text","Inter",sans-serif; font-size: 14px; }
menuitem:hover { background-color: #2563eb; color: #ffffff; }
separator { background-color: rgba(255,255,255,0.14); min-height: 1px; margin: 5px 6px; }
"""

def run(cmd):
    try:
        subprocess.Popen(cmd)
    except Exception as e:
        print("apple-menu: errore", cmd, e)

def about(*_):
    try:
        distro = subprocess.run(["bash", "-lc", "lsb_release -ds 2>/dev/null"],
                                capture_output=True, text=True).stdout.strip()
    except Exception:
        distro = ""
    mem = ""
    try:
        with open("/proc/meminfo") as f:
            kb = int(f.readline().split()[1]); mem = f"{kb/1048576:.1f} GB"
    except Exception:
        pass
    body = (f"{distro or platform.system()}\n"
            f"Kernel: {platform.release()}\n"
            f"Processore: {platform.machine()}\n"
            f"Memoria: {mem}")
    d = Gtk.MessageDialog(None, 0, Gtk.MessageType.INFO, Gtk.ButtonsType.OK,
                          "Informazioni su questo Mac")
    d.format_secondary_text(body)
    d.set_keep_above(True)
    d.run(); d.destroy()

def build_menu():
    menu = Gtk.Menu()
    def item(label, cb):
        mi = Gtk.MenuItem(label=label)
        mi.connect("activate", cb)
        menu.append(mi)
    def sep():
        menu.append(Gtk.SeparatorMenuItem())
    item("Informazioni su questo Mac", about)
    sep()
    item("Impostazioni di Sistema…", lambda *_: run(["xfce4-settings-manager"]))
    item("App Store…",               lambda *_: run(["xdg-open", "https://flathub.org"]))
    sep()
    item("Uscita forzata…",          lambda *_: run(["xkill"]))
    sep()
    # azioni power instradate sul dialogo macOS (mai il dialogo XFCE di default)
    powr = (lambda: run([POWER])) if os.path.exists(POWER) else None
    item("Stop",         lambda *_: run([SESSION, "-s"]))
    item("Riavvia…",     lambda *_: (powr() if powr else run([SESSION, "-r"])))
    item("Spegni…",      lambda *_: (powr() if powr else run([SESSION, "-h"])))
    sep()
    item("Blocca schermo", lambda *_: run(["xflock4"]))
    item("Esci…",          lambda *_: (powr() if powr else run([SESSION, "-l"])))
    menu.show_all()
    return menu

def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    screen = Gdk.Screen.get_default()
    prov = Gtk.CssProvider(); prov.load_from_data(CSS)
    Gtk.StyleContext.add_provider_for_screen(
        screen, prov, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
    menu = build_menu()
    menu.connect("selection-done", lambda *_: GLib.timeout_add(80, Gtk.main_quit))
    # ancorato in alto a sinistra (sotto il logo nel pannello), senza serve un
    # evento: popup_at_rect sulla root window.
    root = Gdk.get_default_root_window()
    rect = Gdk.Rectangle(); rect.x, rect.y, rect.width, rect.height = 6, 2, 1, 1
    menu.popup_at_rect(root, rect, Gdk.Gravity.SOUTH_WEST, Gdk.Gravity.NORTH_WEST, None)
    Gtk.main()

if __name__ == "__main__":
    main()
