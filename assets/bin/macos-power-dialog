#!/usr/bin/env python3
# Dialogo "spegnimento" in stile macOS per XFCE — sostituisce xfce4-session-logout.
# Pannello scuro translucido arrotondato, bottoni circolari (Sospendi/Riavvia/Spegni)
# + Disconnetti/Annulla. Esegue le azioni via xfce4-session-logout.
import gi, subprocess, signal
gi.require_version("Gtk", "3.0")
from gi.repository import Gtk, Gdk, GdkPixbuf, GLib

SESSION = "/usr/bin/xfce4-session-logout"

# azione -> argomenti di xfce4-session-logout
ACTIONS = {
    "suspend":  [SESSION, "-s"],
    "reboot":   [SESSION, "-r", "-f"],
    "halt":     [SESSION, "-h", "-f"],
    "logout":   [SESSION, "-l"],
}

# per ogni voce: lista di nomi icona simbolica (si usa la prima disponibile), etichetta, azione
ITEMS = [
    (["weather-clear-night-symbolic", "media-playback-pause-symbolic"], "Sospendi", "suspend"),
    (["system-reboot-symbolic", "view-refresh-symbolic"],               "Riavvia",  "reboot"),
    (["system-shutdown-symbolic", "system-shutdown"],                   "Spegni",   "halt"),
]

CSS = b"""
#root { background-color: rgba(28,28,30,0.82); border-radius: 36px;
        border: 1px solid rgba(255,255,255,0.10); }
#heading { color: #ffffff; font-family: "Inter Display","Inter",sans-serif;
           font-size: 38px; font-weight: 600; }
.circle { background-color: rgba(255,255,255,0.12);
          border: 1px solid rgba(255,255,255,0.14);
          border-radius: 75px; min-width: 150px; min-height: 150px;
          padding: 0; transition: background-color .12s ease; }
.circle:hover { background-color: rgba(255,255,255,0.22); }
.circle image { color: #ffffff; }
.itemlabel { color: rgba(255,255,255,0.92);
             font-family: "Inter Display","Inter",sans-serif; font-size: 28px; }
.textbtn { background: none; border: none; box-shadow: none; padding: 14px 34px;
           border-radius: 20px; color: rgba(255,255,255,0.92);
           font-family: "Inter Display","Inter",sans-serif; font-size: 30px; }
.textbtn:hover { background-color: rgba(255,255,255,0.14); }
.danger { color: #ff6b66; }
"""

def first_icon(theme, names):
    for n in names:
        if theme.has_icon(n):
            return n
    return names[-1]

class PowerDialog(Gtk.Window):
    def __init__(self):
        super().__init__(type=Gtk.WindowType.TOPLEVEL)
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_skip_taskbar_hint(True)
        self.set_skip_pager_hint(True)
        self.set_keep_above(True)
        self.set_position(Gtk.WindowPosition.CENTER_ALWAYS)
        self.set_type_hint(Gdk.WindowTypeHint.DIALOG)
        self.set_app_paintable(True)
        # visual RGBA per la translucenza
        screen = self.get_screen()
        vis = screen.get_rgba_visual()
        if vis:
            self.set_visual(vis)

        prov = Gtk.CssProvider(); prov.load_from_data(CSS)
        Gtk.StyleContext.add_provider_for_screen(
            screen, prov, Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        theme = Gtk.IconTheme.get_default()

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=30)
        root.set_name("root")
        root.set_margin_top(46); root.set_margin_bottom(38)
        root.set_margin_start(60); root.set_margin_end(60)
        self.add(root)

        heading = Gtk.Label(label="Vuoi spegnere il computer?")
        heading.set_name("heading")
        root.pack_start(heading, False, False, 0)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=44)
        row.set_halign(Gtk.Align.CENTER)
        root.pack_start(row, False, False, 10)

        for names, label, action in ITEMS:
            col = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=14)
            btn = Gtk.Button(); btn.get_style_context().add_class("circle")
            img = Gtk.Image.new_from_icon_name(first_icon(theme, names), Gtk.IconSize.DIALOG)
            img.set_pixel_size(64)
            btn.set_image(img)
            btn.connect("clicked", self.on_action, action)
            lbl = Gtk.Label(label=label); lbl.get_style_context().add_class("itemlabel")
            col.pack_start(btn, False, False, 0)
            col.pack_start(lbl, False, False, 0)
            row.pack_start(col, False, False, 0)

        bottom = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=18)
        bottom.set_halign(Gtk.Align.CENTER)
        root.pack_start(bottom, False, False, 6)

        b_logout = Gtk.Button(label="Disconnetti")
        b_logout.get_style_context().add_class("textbtn")
        b_logout.connect("clicked", self.on_action, "logout")
        b_cancel = Gtk.Button(label="Annulla")
        b_cancel.get_style_context().add_class("textbtn")
        b_cancel.connect("clicked", lambda *_: self.close())
        bottom.pack_start(b_logout, False, False, 0)
        bottom.pack_start(b_cancel, False, False, 0)

        self.connect("key-press-event", self.on_key)
        self.connect("destroy", Gtk.main_quit)

    def on_key(self, _w, ev):
        if ev.keyval == Gdk.KEY_Escape:
            self.close()

    def on_action(self, _w, action):
        try:
            subprocess.Popen(ACTIONS[action])
        except Exception as e:
            print("errore azione", action, e)
        self.close()

def main():
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    win = PowerDialog()
    win.show_all()
    win.present()
    Gtk.main()

if __name__ == "__main__":
    main()
